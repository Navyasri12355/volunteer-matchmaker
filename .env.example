# Volunteer Matchmaker Environment Configuration
# Copy this to .env and update values as needed

# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local development:
#   DATABASE_URL=postgresql://user:password@localhost:5432/volunteer_db
# Cloud SQL:
#   DATABASE_URL=postgresql://user:password@1.2.3.4:5432/volunteer_db
# Docker:
#   DATABASE_URL=postgresql://postgres:postgres@db:5432/volunteer_db
DATABASE_URL=postgresql://user:password@localhost:5432/volunteer_db

# ─── Google Cloud ──────────────────────────────────────────────────────────
# GCP project ID (required for GCP services)
GCP_PROJECT=your-gcp-project-id

# GCP region for services (defaults to us-central1)
GCP_LOCATION=us-central1

# Path to GCP service account JSON credentials
# Leave empty to use Application Default Credentials
GOOGLE_APPLICATION_CREDENTIALS=

# ─── NLP Feature Flags ──────────────────────────────────────────────────────
# Use Vertex AI for semantic embeddings (fallback: TF-IDF)
USE_VERTEX_EMBEDDINGS=true

# Use Cloud Natural Language API for entity extraction (fallback: regex)
USE_GCP_NL_API=true

# Use Cloud Vision API for certificate OCR (fallback: manual review)
USE_CLOUD_VISION=true

# Use Cloud Translation API for document translation (fallback: untranslated)
USE_CLOUD_TRANSLATE=true

# ─── Severity Scoring ──────────────────────────────────────────────────────
# Severity score thresholds (0-1)
SEVERITY_BAND_CRITICAL=0.70   # Events ≥ this score are CRITICAL
SEVERITY_BAND_MODERATE=0.40   # Events ≥ this score are MODERATE

# ─── Trust Scoring ─────────────────────────────────────────────────────────
# Minimum NGO trust score to create events
NGO_TRUST_GATE_THRESHOLD=0.40

# Exponential moving average alpha for trust scoring (0-1)
# Higher = newer audits matter more, lower = older history matters more
NGO_TRUST_EMA_ALPHA=0.25

# ─── API Server ────────────────────────────────────────────────────────────
# Host to bind to
API_HOST=0.0.0.0

# Port to listen on
API_PORT=8080

# Enable debug mode (reloads on file change)
DEBUG=false

# ─── Firebase (optional, for file storage) ──────────────────────────────────
# Firebase Storage bucket name (e.g., "my-project.appspot.com")
# Leave empty to disable Firebase Storage
FIREBASE_STORAGE_BUCKET=

# ─── Offline Mode ──────────────────────────────────────────────────────────
# Set all feature flags to false to run completely offline/local
# Example:
#   USE_VERTEX_EMBEDDINGS=false
#   USE_GCP_NL_API=false
#   USE_CLOUD_VISION=false
#   USE_CLOUD_TRANSLATE=false
